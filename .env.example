# Copy to .env (kept OUTSIDE the web root — one level above public/) and fill in.
# On Cyon, create the database + user in the control panel and paste the values here.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=vakaros
DB_USER=vakaros
DB_PASS=change-me

# Where gzip track files are written. Keep this OUTSIDE the web root.
STORAGE_DIR=/home/USER/vakaros-storage
